# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/pharmaspot

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# CORS Configuration (set specific origins in production, e.g., "http://localhost:3000,https://yourdomain.com")
CORS_ORIGIN=*

# Notification System Configuration
# Check interval in milliseconds (default: 60000 = 1 minute)
NOTIFICATION_CHECK_INTERVAL=60000

# Default Admin Password (change in production)
# DEFAULT_ADMIN_PASSWORD=admin

# Mock Authentication (only used when MongoDB is unavailable)
# WARNING: Change these in production or when exposing to network
MOCK_ADMIN_USERNAME=admin
MOCK_ADMIN_PASSWORD=admin
MOCK_DEMO_USERNAME=demo
MOCK_DEMO_PASSWORD=demo

# EmailJS Configuration
# Get these from https://www.emailjs.com/
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Email Configuration for OTP (Nodemailer)
# For Gmail, use 'gmail' as service
# For other providers, check nodemailer documentation
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Security Configuration
# Master encryption key for encrypting private keys at rest
# IMPORTANT: Generate a strong random key in production (at least 32 characters)
# Example: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=change-this-to-a-secure-random-key-in-production

# Enable security operation logging in production (default: false)
ENABLE_SECURITY_LOGS=false
